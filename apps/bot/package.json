{
  "name": "@jahonbozor/bot",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jahonbozor/logger": "workspace:*",
    "@jahonbozor/schemas": "workspace:*",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "croner": "^10.0.1",
    "grammy": "^1.35.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "latest",
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  }
}
