{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "tabWidth": 4,
  "useTabs": false,
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "auto",
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.prisma",
      "options": { "tabWidth": 2 }
    },
    {
      "files": "*.{json,yml,yaml}",
      "options": { "tabWidth": 2 }
    }
  ]
}
