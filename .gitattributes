# Normalize line endings to LF on checkin, keep LF on checkout for all text files.
* text=auto eol=lf

# Explicit binary types (do not touch)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.mov binary
